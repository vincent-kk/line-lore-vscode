{
  "name": "pr-tracer",
  "displayName": "PR Tracer",
  "description": "Trace any code line back to its origin Pull Request",
  "version": "1.0.0",
  "publisher": "vincent-kkelvin",
  "repository": {
    "type": "git",
    "url": "https://github.com/vincent-kk/line-lore-vscode"
  },
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "git",
    "blame",
    "pull-request",
    "trace",
    "pr"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "PR Tracer executes git commands and requires a trusted workspace."
    },
    "virtualWorkspaces": {
      "supported": false,
      "description": "PR Tracer requires local filesystem and git access."
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "prTracer.tracePR",
        "title": "Line Lore: Trace PR"
      },
      {
        "command": "prTracer.tracePRRange",
        "title": "Line Lore: Trace PR (Range)"
      },
      {
        "command": "prTracer.healthCheck",
        "title": "Line Lore: Health Check"
      },
      {
        "command": "prTracer.clearCache",
        "title": "Line Lore: Clear Cache"
      },
      {
        "command": "prTracer.graphExplore",
        "title": "Line Lore: Explore Graph"
      },
      {
        "command": "prTracer.traceFromHover",
        "title": "Line Lore: Trace From Hover"
      },
      {
        "command": "prTracer.traceOriginFromHover",
        "title": "Line Lore: Trace Origin From Hover"
      },
      {
        "command": "prTracer.copyPrLink",
        "title": "Line Lore: Copy PR Link"
      },
      {
        "command": "prTracer.showDetails",
        "title": "Line Lore: Show Details"
      },
      {
        "command": "prTracer.clearAllDecorations",
        "title": "Line Lore: Clear All Decorations"
      },
      {
        "command": "prTracer.clearDecoration",
        "title": "Line Lore: Clear Decoration"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "prTracer.tracePR",
          "when": "editorTextFocus && resourceScheme == file && prTracer.gitDetected",
          "group": "navigation"
        },
        {
          "command": "prTracer.tracePRRange",
          "when": "editorTextFocus && editorHasSelection && resourceScheme == file && prTracer.gitDetected",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "prTracer.tracePR",
          "when": "prTracer.gitDetected"
        },
        {
          "command": "prTracer.tracePRRange",
          "when": "prTracer.gitDetected"
        },
        {
          "command": "prTracer.healthCheck",
          "when": "prTracer.gitDetected"
        },
        {
          "command": "prTracer.clearCache",
          "when": "prTracer.gitDetected"
        },
        {
          "command": "prTracer.graphExplore",
          "when": "prTracer.gitDetected"
        },
        {
          "command": "prTracer.traceFromHover",
          "when": "false"
        },
        {
          "command": "prTracer.traceOriginFromHover",
          "when": "false"
        },
        {
          "command": "prTracer.copyPrLink",
          "when": "false"
        },
        {
          "command": "prTracer.showDetails",
          "when": "false"
        },
        {
          "command": "prTracer.clearAllDecorations",
          "when": "prTracer.gitDetected"
        },
        {
          "command": "prTracer.clearDecoration",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "PR Tracer",
      "properties": {
        "prTracer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable PR Tracer extension"
        },
        "prTracer.hoverProvider.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show 'Trace PR' link in hover popup"
        },
        "prTracer.inlineDecoration.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show PR number inline after trace"
        },
        "prTracer.inlineDecoration.timeout": {
          "type": "number",
          "default": 30,
          "description": "Seconds before inline decoration auto-removes (0 = never)"
        },
        "prTracer.trace.deep": {
          "type": "boolean",
          "default": false,
          "description": "Enable deep trace for squash merges by default"
        },
        "prTracer.trace.noAst": {
          "type": "boolean",
          "default": false,
          "description": "Disable AST analysis"
        },
        "prTracer.trace.noCache": {
          "type": "boolean",
          "default": false,
          "description": "Disable caching"
        }
      }
    }
  },
  "dependencies": {
    "@lumy-pack/line-lore": "0.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "prettier": "^3.8.1",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/node": "^22",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.13.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.1.0"
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "vsce:package": "pnpm vsce package --no-dependencies --no-yarn",
    "vsce:publish": "pnpm vsce publish --no-dependencies --no-yarn",
    "version:patch": "bash scripts/version.sh patch",
    "version:minor": "bash scripts/version.sh minor",
    "version:major": "bash scripts/version.sh major"
  }
}
